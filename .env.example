# ═══════════════════════════════════════════════════════════
# APPLICATION
# ═══════════════════════════════════════════════════════════

APP_NAME="Aqari Smart"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://localtest.me:8000

# ═══════════════════════════════════════════════════════════
# TENANCY
# ═══════════════════════════════════════════════════════════

# Base domain used to resolve subdomain tenants
TENANCY_BASE_DOMAIN=localtest.me

# Session domain with leading dot for subdomain sharing
SESSION_DOMAIN=.localtest.me

# Sanctum stateful domains
SANCTUM_STATEFUL_DOMAINS=localhost:8000,127.0.0.1:8000,localtest.me

# ═══════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=aqarismart
DB_USERNAME=root
DB_PASSWORD=

# ═══════════════════════════════════════════════════════════
# SUPER ADMIN ACCESS
# ═══════════════════════════════════════════════════════════

SUPER_ADMIN_EMAILS=admin@aqarismart.com
SEED_SUPER_ADMIN_PASSWORD=Admin@123456
SEED_TENANT_OWNER_PASSWORD=Owner@123456
SEED_AGENT_PASSWORD=Agent@123456
PRELAUNCH_BACKUP_DIR=
PRELAUNCH_MAINTENANCE_SECRET=aqari-prelaunch-bypass

# ═══════════════════════════════════════════════════════════
# MAIL
# ═══════════════════════════════════════════════════════════

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@aqarismart.com"
MAIL_FROM_NAME="${APP_NAME}"

# ═══════════════════════════════════════════════════════════
# STORAGE & FILESYSTEM
# ═══════════════════════════════════════════════════════════

FILESYSTEM_DISK=public

# ═══════════════════════════════════════════════════════════
# CACHE, SESSION & QUEUE
# ═══════════════════════════════════════════════════════════

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# For production, use redis:
# CACHE_STORE=redis
# SESSION_DRIVER=redis
# QUEUE_CONNECTION=redis
# SESSION_SECURE_COOKIE=true

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ═══════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ═══════════════════════════════════════════════════════════
# OPTIONAL: STRIPE BILLING
# ═══════════════════════════════════════════════════════════

# STRIPE_KEY=
# STRIPE_SECRET=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STARTER=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_ENTERPRISE=

# ═══════════════════════════════════════════════════════════
# OPTIONAL: NATIVEPHP MOBILE
# ═══════════════════════════════════════════════════════════

# Remote API URL for NativePHP production builds (mobile app fetches from this server's MySQL)
# Leave empty for local dev. Example: https://aqarismart.com
# NATIVEPHP_REMOTE_API_URL=

# ═══════════════════════════════════════════════════════════
# OPTIONAL: VITE DEV SERVER
# ═══════════════════════════════════════════════════════════

# VITE_APP_NAME="${APP_NAME}"


